{
  "name": "matter-cameras",
  "version": "0.3.5-beta",
  "description": "Bridge RTSP/ONVIF streams to Matter 1.5 cameras for SmartThings",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "start": "tsx src/main.ts",
    "build": "tsc",
    "serve": "node dist/main.js",
    "bump-deploy": "node scripts/bump-deploy-version.mjs",
    "setup": "bash scripts/setup.sh",
    "deploy": "node scripts/bump-deploy-version.mjs && npm run build && bash scripts/deploy.sh --no-bump",
    "quick-deploy": "node scripts/bump-deploy-version.mjs && npm run build && bash scripts/quick-deploy.sh --no-bump",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "matter",
    "rtsp",
    "onvif",
    "smartthings",
    "camera",
    "iot"
  ],
  "author": "patricktd",
  "license": "ISC",
  "dependencies": {
    "@matter/general": "^0.17.1",
    "@matter/main": "^0.17.1",
    "@matter/nodejs": "^0.17.1",
    "@matter/node": "^0.17.1",
    "@matter/types": "^0.17.1",
    "@project-chip/matter.js": "^0.17.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "lowdb": "^7.0.1"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
