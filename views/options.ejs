<%- include('partials/header', { pageTitle: 'Options', bridgeStatus, appVersion, activePage: 'options' }) %>

    <div class="card options-page">
        <h2>SmartThings</h2>
        <p class="field-hint" style="margin-top: 0;">
            Motion automations use <strong>OccupancySensing</strong> on the hub (matter-switch maps it to
            <em>Motion detected</em>). The bridge always reports occupancy during <code>ZoneTriggered</code>
            events. Card motion icons and routines share the same signal.
        </p>
        <p class="field-hint">
            After hub firmware or driver updates, open <strong>MatterCameras Bridge</strong> in the app and
            pull down to refresh so cameras re-profile.
        </p>
    </div>

    <div class="card options-page">
        <h2>Bridge</h2>
        <p class="field-hint" style="margin-top: 0;">
            Restart reloads all cameras and refreshes the Matter parts list for SmartThings.
        </p>
        <form action="/api/restart" method="POST" class="inline-form"
            onsubmit="return confirm('Restart the bridge? SmartThings may take ~30s to reconnect.');">
            <input type="hidden" name="returnTo" value="/options">
            <button type="submit" class="btn btn-ghost btn-sm">Restart Bridge</button>
        </form>
    </div>

    <%- include('partials/footer') %>
