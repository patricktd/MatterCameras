<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Matter Cameras Bridge — <%= typeof pageTitle !== 'undefined' ? pageTitle : 'Dashboard' %></title>
    <link rel="icon" type="image/png" href="/images/logo.png">
    <link rel="stylesheet" href="/css/dashboard.css">
    <% if (typeof extraStylesheets !== 'undefined' && Array.isArray(extraStylesheets)) { %>
        <% extraStylesheets.forEach(stylesheet => { %>
            <link rel="stylesheet" href="<%= stylesheet %>">
        <% }) %>
    <% } %>
</head>

<body<% if (typeof bodyClass !== 'undefined' && bodyClass) { %> class="<%= bodyClass %>"<% } %>>
    <div class="container">
        <header>
            <div class="header-title">
                <h1><a href="/" class="header-home-link"><img src="/images/logo.png" alt="" class="header-logo">Matter Cameras Bridge</a></h1>
                <% if (typeof pageTitle !== 'undefined' && pageTitle !== 'Dashboard') { %>
                    <span class="header-page-title"><%= pageTitle %></span>
                <% } %>
            </div>
            <div class="header-right">
                <div id="connection-status">
                    Bridge Status:
                    <span
                        class="status-badge <%= bridgeStatus === 'Commissioned' ? 'status-commissioned' : 'status-ready' %>">
                        <%= bridgeStatus %>
                    </span>
                </div>
                <div class="header-actions">
                    <% if (typeof activePage === 'undefined' || activePage !== 'dashboard') { %>
                        <a href="/" class="btn btn-secondary btn-sm">Dashboard</a>
                    <% } %>
                    <% if (typeof activePage === 'undefined' || activePage !== 'add-camera') { %>
                        <a href="/cameras/add" class="btn btn-sm">Add Camera</a>
                    <% } %>
                    <% if (typeof activePage === 'undefined' || activePage !== 'options') { %>
                        <a href="/options" class="btn btn-ghost btn-sm">Options</a>
                    <% } %>
                    <%- include('bridge-restart-form', { returnTo: typeof returnTo !== 'undefined' ? returnTo : '', bridgeRestartPending }) %>
                </div>
            </div>
        </header>
        <%- include('info-bar') %>
        <%- include('brand-disclaimer') %>
