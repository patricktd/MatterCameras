<%- include('partials/header', { pageTitle: 'Dashboard', bridgeStatus, appVersion, activePage: 'dashboard' }) %>

    <% const isCommissioned = bridgeStatus === 'Commissioned'; %>
    <% const addFormOpen = cameras.length === 0; %>

    <div class="main-grid">

        <% if (cameras.length > 4) { %>
            <div class="notice-banner notice-banner--warning main-grid-full">
                <strong>SmartThings preview limit:</strong> the mobile app lets you pick up to
                <strong>4 cameras</strong> for cloud monitoring card previews. Live view works for all
                <%= cameras.length %> cameras; cameras outside your selection may show a stale or empty card.
                Change the selection in SmartThings → Home Monitor → Cameras.
            </div>
        <% } %>

        <div>
            <div class="card">
                <div class="card-header-row card-header-row--actions">
                    <button type="button" id="toggle-add-camera" class="btn btn-sm">
                        <%= addFormOpen ? '− Cancel' : '+ Add Camera' %>
                    </button>
                </div>

                <%- include('partials/add-camera-panel', { addFormOpen, isCommissioned, protectController }) %>
            </div>

            <% if (cameras.length === 0) { %>
                <div class="empty-state">
                    <p>No cameras added yet. Click <strong>+ Add Camera</strong> and pick UniFi Protect, Reolink, ONVIF, or paste an RTSP URL.</p>
                    <% if (!isCommissioned) { %>
                        <p style="font-size: 0.8rem;">Tip: pair the bridge with SmartThings first, then add your cameras.</p>
                    <% } %>
                </div>
            <% } %>

            <div class="camera-list">
                <% cameras.forEach(cam => { %>
                    <div class="camera-card" data-camera-id="<%= cam.id %>">
                        <div class="camera-view">
                            <div class="camera-preview">
                                <div class="camera-preview-placeholder">No signal</div>
                                <img class="camera-preview-img" alt="<%= cam.name %> preview">
                                <span class="camera-status-badge camera-status-badge--checking">Checking…</span>
                            </div>
                            <div class="camera-view-header">
                                <h3><%= cam.name %></h3>
                                <div class="camera-actions">
                                    <button type="button" class="btn btn-secondary btn-sm btn-edit">Edit</button>
                                    <form action="/api/cameras/<%= cam.id %>/delete" method="POST" style="display:inline;"
                                        onsubmit="return confirm('Remove camera <%= cam.name %>?');">
                                        <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                                    </form>
                                </div>
                            </div>
                            <% const motionLabel = (() => {
                                const s = cam.motionSource || 'frame-diff';
                                if (s === 'auto') return 'Motion: Auto';
                                if (s === 'onvif') return 'Motion: ONVIF';
                                if (s === 'reolink-native') return 'Motion: Reolink';
                                if (s === 'unifi-protect') return 'Motion: UniFi Protect';
                                return 'Motion: Frame diff';
                            })(); %>
                            <% if (cam.motionSource && cam.motionSource !== 'frame-diff') { %>
                                <p class="camera-meta"><%= motionLabel %></p>
                            <% } %>
                            <% if (cam.codec) { %>
                                <p class="camera-meta">Codec: <%= cam.codec.toUpperCase() %></p>
                            <% } %>
                        </div>

                        <form class="camera-edit hidden" action="/api/cameras/<%= cam.id %>" method="POST">
                            <label>Camera Name</label>
                            <input type="text" name="name" value="<%= cam.name %>" required>

                            <label>RTSP / ONVIF Stream URL</label>
                            <input type="text" name="rtspUrl" value="<%= cam.rtspUrl %>" required>
                            <p class="field-hint">rtsp://user:password@192.168.x.x:554/stream</p>

                            <details class="advanced-toggle">
                                <summary>Advanced options</summary>
                                <div class="advanced-options">
                                    <label>Video Codec (Optional)</label>
                                    <select name="codec">
                                        <option value="" <%= !cam.codec ? 'selected' : '' %>>Auto Detect</option>
                                        <option value="h264" <%= cam.codec === 'h264' ? 'selected' : '' %>>H.264</option>
                                        <option value="h265" <%= cam.codec === 'h265' ? 'selected' : '' %>>H.265</option>
                                    </select>

                                    <%- include('partials/motion-options', {
                                        idPrefix: 'edit-' + cam.id,
                                        selectedMotion: cam.motionSource || 'frame-diff',
                                        onvifUrl: cam.onvifUrl || '',
                                        protectHost: cam.protectHost || '',
                                        protectCameraId: cam.protectCameraId || '',
                                        reolinkChannel: cam.reolinkChannel ?? 0,
                                        manufacturer: cam.manufacturer || '',
                                        model: cam.model || '',
                                    }) %>
                                </div>
                            </details>

                            <div class="camera-actions">
                                <button type="submit" class="btn btn-sm">Save</button>
                                <button type="button" class="btn btn-secondary btn-sm btn-duplicate"
                                    data-source-name="<%= cam.name %>">Duplicate</button>
                                <button type="button" class="btn btn-secondary btn-sm btn-cancel">Cancel</button>
                            </div>
                        </form>
                    </div>
                <% }) %>
            </div>
        </div>

        <div>
            <div class="card qr-section">
                <h2>Pairing (SmartThings)</h2>

                <% if (isCommissioned) { %>
                    <div class="pairing-success">
                        <p><strong>Bridge paired successfully.</strong></p>
                        <p style="margin-top: 8px; color: var(--text-secondary);">
                            Add or remove cameras on the left. When the bridge is paired, the app restarts
                            automatically so SmartThings picks up the updated camera list (about 15 seconds).
                        </p>
                    </div>
                <% } else { %>
                    <p class="pairing-hint">
                        Your hub and this server must be on the same local network.
                        If the QR code does not work, use the manual pairing code below.
                    </p>
                <% } %>

                <% if (pairingInfo && pairingInfo.qrCode) { %>
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=<%= encodeURIComponent(pairingInfo.qrCode) %>"
                        alt="Matter Pairing QR">

                    <div style="margin-top: 16px;">
                        <small style="color: var(--text-secondary);">Manual code (SmartThings → Matter → Enter code)</small>
                        <span class="pairing-code"><%= pairingInfo.manualPairingCode %></span>
                    </div>

                    <details class="technical-details">
                        <summary>Show technical details</summary>
                        <pre><%= pairingInfo.qrCode %></pre>
                    </details>
                <% } else if (!isCommissioned) { %>
                    <p>Starting bridge...</p>
                <% } %>

                <div class="pairing-actions">
                    <button type="button" onclick="window.location.reload()" class="btn btn-ghost">Refresh QR</button>
                </div>

                <div class="danger-zone">
                    <h3>Reset Pairing</h3>
                    <p>
                        Factory-reset removes all Matter pairings. You will need to scan the QR code again in SmartThings.
                        Your camera list is not affected.
                    </p>
                    <form action="/api/reset" method="POST"
                        onsubmit="return confirm('WARNING: This will factory reset the Matter Bridge and remove all pairings. Are you sure?');">
                        <button type="submit" class="btn btn-danger" style="width: 100%;">Reset Pairing</button>
                    </form>
                </div>
            </div>
        </div>

    </div>

    <div class="card troubleshooting">
        <details id="troubleshooting-section">
            <summary>Logs</summary>
            <p class="troubleshooting-hint">
                System logs for advanced users. Open this section if you need to diagnose connection or streaming issues.
            </p>
            <div class="log-toolbar">
                <button type="button" id="log-scroll-toggle" class="btn btn-secondary btn-sm" aria-pressed="false">
                    Pause scroll
                </button>
            </div>
            <div id="log-container">
                <div class="log-placeholder">Waiting for logs...</div>
            </div>
        </details>
    </div>

    <script src="/js/dashboard.js"></script>

    <%- include('partials/footer') %>
